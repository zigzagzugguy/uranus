<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Cosmic Prototype</title>

<style>

body{
margin:0;
background:black;
overflow:hidden;
color:white;
font-family:Arial;
display:flex;
justify-content:center;
align-items:center;
height:100vh;
flex-direction:column;
}

/* STARFIELD */

.stars{
position:absolute;
width:100%;
height:100%;
background:
radial-gradient(2px 2px at 20% 30%, white, transparent),
radial-gradient(2px 2px at 70% 80%, white, transparent),
radial-gradient(2px 2px at 50% 50%, white, transparent),
radial-gradient(2px 2px at 90% 40%, white, transparent),
radial-gradient(2px 2px at 10% 70%, white, transparent);
animation:moveStars 60s linear infinite;
}

@keyframes moveStars{
from{transform:translateY(0)}
to{transform:translateY(-1000px)}
}

/* SUN */

.sun{
width:140px;
height:140px;
background:radial-gradient(circle,#fff176,#ff9800,#ff3d00);
border-radius:50%;
position:absolute;
box-shadow:0 0 80px #ff9800,0 0 160px #ff5722;
animation:pulse 4s infinite;
cursor:pointer;
}

@keyframes pulse{
0%{box-shadow:0 0 60px #ff9800}
50%{box-shadow:0 0 140px #ff5722}
100%{box-shadow:0 0 60px #ff9800}
}

/* ORBITS */

.orbit{
position:absolute;
border:1px solid rgba(255,255,255,0.08);
border-radius:50%;
animation:spin linear infinite;
}

@keyframes spin{
from{transform:rotate(0)}
to{transform:rotate(360deg)}
}

.planet{
position:absolute;
top:-6px;
left:50%;
border-radius:50%;
}

/* planets */

.orbit1{width:200px;height:200px;animation-duration:8s;}
.orbit1 .planet{width:10px;height:10px;background:#a5d6ff;}

.orbit2{width:300px;height:300px;animation-duration:14s;}
.orbit2 .planet{width:14px;height:14px;background:#ffab91;}

.orbit3{width:420px;height:420px;animation-duration:20s;}
.orbit3 .planet{width:18px;height:18px;background:#80cbc4;}

.orbit4{width:540px;height:540px;animation-duration:28s;}
.orbit4 .planet{width:20px;height:20px;background:#b39ddb;}

/* population counter */

.counter{
position:absolute;
bottom:120px;
text-align:center;
font-size:28px;
}

.text{
font-size:18px;
opacity:0.7;
margin-top:10px;
}

/* button */

button{
position:absolute;
bottom:40px;
background:#111;
color:white;
border:1px solid #444;
padding:12px 22px;
border-radius:20px;
cursor:pointer;
transition:0.3s;
}

button:hover{
background:#222;
}

</style>
</head>

<body>

<div class="stars"></div>

<div class="sun" id="sun"></div>

<div class="orbit orbit1"><div class="planet"></div></div>
<div class="orbit orbit2"><div class="planet"></div></div>
<div class="orbit orbit3"><div class="planet"></div></div>
<div class="orbit orbit4"><div class="planet"></div></div>

<div class="counter">
<div id="population">8,091,000,000</div>
<div class="text">I love only 1gender</div>
</div>

<button onclick="rickroll()">Easter Egg</button>

<script>

/* population counter */

let pop = 8091000000

setInterval(()=>{
pop += Math.floor(Math.random()*3)
document.getElementById("population").innerText = pop.toLocaleString()
},1000)

/* rickroll */

function rickroll(){
window.open("https://www.youtube.com/watch?v=dQw4w9WgXcQ")
}

/* secret trigger: click sun 5 times */

let clicks = 0
document.getElementById("sun").onclick = () => {
clicks++
if(clicks == 5){
rickroll()
}
}

</script>

</body>
</html>
